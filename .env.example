# Copy to .env for local development. Do not commit .env.
# On Netlify, set these under Site settings → Environment variables.

# Optional — defaults to https://www.worldcubeassociation.org
VITE_WCA_ORIGIN=

# Required for production OAuth (WCA Application ID, not the secret)
VITE_WCA_OAUTH_CLIENT_ID=

# Optional Google Analytics measurement ID (e.g. G-XXXXXXXXXX)
VITE_GA_MEASUREMENT_ID=
